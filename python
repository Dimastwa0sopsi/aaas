# ========== /start ==========
@dp.message(Command("start"))
async def cmd_start(message: Message):
    user_id = message.from_user.id
    logger.info(f"Пользователь {user_id} запустил бота")

    if user_id == ADMIN_ID:
        await message.answer("👑 <b>Админ-панель</b>\nВыберите действие:", reply_markup=get_admin_keyboard())
        return

    args = message.text.split()
    if len(args) > 1 and args[1].startswith("order_"):
        order_id = args[1].replace("order_", "")
        order = orders_db.get(order_id)
        if order:
            await message.answer(
                f"📦 <b>Ваш заказ!</b>\n\n"
                f"🆔 ID: <code>{order_id}</code>\n"
                f"👤 ФИО: {order['fio']}\n"
                f"🔗 Ссылка: {order['link']}\n"
                f"🔢 Кол-во отзывов: {order['count']}\n"
                f"🌐 Сервис: {order['service']}\n"
                f"💰 Сумма: {order['price']} Stars\n\n"
                f"<i>Нажмите кнопку для оплаты:</i>",
                reply_markup=get_payment_keyboard(order_id, order['price'])
            )
            return

    await message.answer(
        "👋 <b>Gimfeedback Bot</b>\n\n"
        "Накрутка отзывов на популярных площадках.\n"
        "Выберите действие:",
        reply_markup=get_main_keyboard()
    )

