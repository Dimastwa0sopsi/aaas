BOT_TOKEN = os.getenv("BOT_TOKEN", "8909688885:AAFKrn9n2FHBRGkoQdiC0KXK-viz9Ti8mz0")
ADMIN_ID = int(os.getenv("ADMIN_ID", "7761721600"))
