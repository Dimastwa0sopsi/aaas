# ========== ДЛЯ РАБОЧИХ ==========
@dp.callback_query(F.data == "for_workers")
async def workers_cb(callback: CallbackQuery, state: FSMContext):
    await callback.message.answer("👷 Введите ваше ФИО:")
    await state.set_state(WorkerStates.waiting_fio)

@dp.message(WorkerStates.waiting_fio)
async def worker_fio(msg: Message, state: FSMContext):
    fio = msg.text.strip()
    uid = msg.from_user.id
    workers_db[uid] = {
        'fio': fio,
        'username': msg.from_user.username or f"id{uid}",
        'active_orders': [],
        'status': 'active'
    }
    logger.info(f"Новый рабочий: {fio}")
    await msg.answer(f"✅ Зарегистрирован: {fio}\nОжидайте заказы.", reply_markup=get_main_keyboard())
    await state.clear()

# ========== АДМИН-МЕНЮ ==========
@dp.callback_query(F.data == "admin_staff")
async def admin_staff(cb: CallbackQuery):
    if not workers_db:
        await cb.message.edit_text("👥 Нет сотрудников.", reply_markup=get_admin_keyboard())
        return
    text = "👥 <b>Сотрудники:</b>\n"
    for uid, w in workers_db.items():
        text += f"• {w['fio']} (@{w['username']}) — {w['status']}\n"
    await cb.message.edit_text(text, reply_markup=get_admin_keyboard())

@dp.callback_query(F.data == "admin_fire")
async def admin_fire(cb: CallbackQuery, state: FSMContext):
    await cb.message.answer("❌ Введите @username для увольнения:")
    await state.set_state(FireStates.waiting_username)

@dp.message(FireStates.waiting_username)
async def fire_by_username(msg: Message, state: FSMContext):
    username = msg.text.strip().replace("@", "")
    fired_uid = None
    for uid, w in workers_db.items():
        if w['username'].lower() == username.lower():
            fired_uid = uid
            break
    if not fired_uid:
        await msg.answer("❌ Не найден.")
        await state.clear()
        return
    workers_db[fired_uid]['status'] = 'fired'
    try:
        await bot.send_message(fired_uid,
            "😞 <b>Вы уволены.</b>\n\n📜 <b>Правила:</b>\n"
            "1. Не разглашать данные заказов.\n"
            "2. Не обманывать клиентов.\n"
            "3. Нарушение — блокировка.")
    except: pass
    await msg.answer(f"✅ @{username} уволен.")
    await state.clear()

@dp.callback_query(F.data == "admin_applications")
async def admin_apps(cb: CallbackQuery):
    pending = [a for a in applications_db.values() if a['status'] == 'pending']
    if not pending:
        await cb.message.edit_text("📋 Нет заявок.", reply_markup=get_admin_keyboard())
        return
    text = "📋 <b>Заявки:</b>\n"
    for app in pending:
        text += f"• {app['fio']} (ID: {app['user_id']})\n"
    await cb.message.edit_text(text, reply_markup=get_admin_keyboard())

# ========== ЗАЯВКИ ==========
@dp.callback_query(F.data.startswith("accept_app_"))
async def accept_app(cb: CallbackQuery):
    app_id = cb.data.replace("accept_app_", "")
    app = applications_db.get(app_id)
    if app:
        app['status'] = 'accepted'
        try: await bot.send_message(app['user_id'], "✅ Заявка одобрена!")
        except: pass
    await cb.message.edit_text("✅ Принято.", reply_markup=get_admin_keyboard())

@dp.callback_query(F.data.startswith("reject_app_"))
async def reject_app(cb: CallbackQuery, state: FSMContext):
    app_id = cb.data.replace("reject_app_", "")
    await state.update_data(reject_app_id=app_id)
    await cb.message.answer("✍️ Причина отказа:")
    await state.set_state(RejectStates.waiting_reason)

@dp.message(RejectStates.waiting_reason)
async def reject_reason(msg: Message, state: FSMContext):
    data = await state.get_data()
    app_id = data.get("reject_app_id")
    reason = msg.text.strip()
    app = applications_db.get(app_id)
    if app:
        app['status'] = 'rejected'
        try: await bot.send_message(app['user_id'], f"❌ Отказ.\nПричина: {reason}")
        except: pass
    await msg.answer("✅ Отклонено.")
    await state.clear()

# ========== ОПЛАТА STARS ==========
@dp.callback_query(F.data.startswith("pay_stars_"))
async def pay_stars(cb: CallbackQuery):
    order_id = cb.data.replace("pay_stars_", "")
    order = orders_db.get(order_id, {})
    price = order.get('price', 0)
    await cb.message.edit_text(
        f"⭐ <b>Оплата Telegram Stars</b>\n\n"
        f"1. Проверьте баланс Stars\n"
        f"2. Перейдите: {SUPPORT_LINK}\n"
        f"3. Отправьте подарок — <b>{price} Stars</b>\n"
        f"4. Ждите подтверждения",
        reply_markup=InlineKeyboardMarkup(inline_keyboard=[
            [InlineKeyboardButton(text="🔗 Перейти", url=SUPPORT_LINK)]
        ])
    )

@dp.callback_query(F.data.startswith("cancel_"))
async def cancel_order(cb: CallbackQuery):
    order_id = cb.data.replace("cancel_", "")
    orders_db.pop(order_id, None)
    await cb.message.edit_text("❌ Отменён.")

# ========== РАБОТА С ЗАКАЗОМ ==========
@dp.callback_query(F.data.startswith("start_work_"))
async def start_work(cb: CallbackQuery):
    parts = cb.data.split("_")
    order_id = parts[2]
    worker_id = int(parts[3])
    order = orders_db.get(order_id, {})
    price = round(order.get('price', 0) * 0.75)
    workers_db[worker_id]['active_orders'].append(order_id)
    await cb.message.edit_text(
        f"🚀 <b>Заказ принят!</b>\n\n"
        f"💰 Оплата: {price} Stars (-25%)\n"
        f"🔗 Ссылка: {order.get('link')}\n"
        f"🌐 Сервис: {order.get('service')}\n\n"
        f"⚠️ Пришлите скрин отзыва."
    )

@dp.callback_query(F.data.startswith("decline_"))
async def decline_order(cb: CallbackQuery):
    await cb.message.edit_text("❌ Отказались.")

# ========== СКРИНЫ ==========
@dp.message(F.photo)
async def handle_screenshot(msg: Message):
    uid = msg.from_user.id
    if uid in workers_db and workers_db[uid]['active_orders']:
        oid = workers_db[uid]['active_orders'][-1]
        await bot.send_photo(
            ADMIN_ID, msg.photo[-1].file_id,
            caption=f"📸 От {workers_db[uid]['fio']}\nЗаказ: {oid}",
            reply_markup=get_admin_verify_keyboard(oid, uid)
        )
        await msg.answer("✅ На проверке.")
    else:
        await msg.answer("❌ Нет активных заказов.")

@dp.callback_query(F.data.startswith("verify_ok_"))
async def verify_ok(cb: CallbackQuery):
    _, _, oid, wid = cb.data.split("_")
    await cb.message.edit_caption(caption=cb.message.caption + "\n\n✅ ОДОБРЕНО")
    await bot.send_message(int(wid), f"✅ Заказ {oid} одобрен!")
    workers_db[int(wid)]['active_orders'].remove(oid)

@dp.callback_query(F.data.startswith("verify_no_"))
async def verify_no(cb: CallbackQuery):
    _, _, oid, wid = cb.data.split("_")
    await cb.message.edit_caption(caption=cb.message.caption + "\n\n❌ ОТКЛОНЕНО")
    await bot.send_message(int(wid), f"❌ Заказ {oid} отклонён. Исправьте.")

# ========== ЗАПУСК ==========
async def main():
    logger.info("Бот запущен!")
    await dp.start_polling(bot)

if __name__ == "__main__":
    asyncio.run(main())
